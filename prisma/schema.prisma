// ─────────────────────────────────────────────
// Generator & Datasource
// ─────────────────────────────────────────────

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Plan
// ─────────────────────────────────────────────

model Plan {
  id        String    @id @default(uuid())
  name      String
  maxUsers  Int
  maxStores Int       @default(1)
  price     Decimal   @db.Decimal(10, 2)
  companies Company[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("plans")
}

// ─────────────────────────────────────────────
// Company
// ─────────────────────────────────────────────

model Company {
  id     String  @id @default(uuid())
  name   String
  cnpj   String? @unique
  active Boolean @default(true)

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  users  User[]
  stores Store[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("companies")
}

// ─────────────────────────────────────────────
// Store
// ─────────────────────────────────────────────

model Store {
  id     String  @id @default(uuid())
  name   String
  active Boolean @default(true)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  products         Product[]
  sales            Sale[]
  financialEntries FinancialEntry[]
  userStores       UserStore[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("stores")
}

// ─────────────────────────────────────────────
// User
// ─────────────────────────────────────────────

model User {
  id       String  @id @default(uuid())
  name     String
  email    String
  password String
  active   Boolean @default(true)
  isOwner  Boolean @default(false)  // acesso total à company, ignora UserStore

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  sessions   Session[]
  sales      Sale[]
  userStores UserStore[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, email])
  @@map("users")
}

model Session {
  id           String   @id @default(uuid())
  refreshToken String   @unique
  expiresAt    DateTime

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@map("sessions")
}

// ─────────────────────────────────────────────
// UserStore (acesso por loja)
// ─────────────────────────────────────────────

model UserStore {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  role UserRole

  createdAt DateTime @default(now())

  @@unique([userId, storeId])
  @@map("user_stores")
}

enum UserRole {
  OWNER
  ADMIN
  EMPLOYEE
}

// ─────────────────────────────────────────────
// Inventory
// ─────────────────────────────────────────────

model Product {
  id    String  @id @default(uuid())
  name  String
  sku   String?
  price Decimal @db.Decimal(10, 2)
  cost  Decimal @default(0) @db.Decimal(10, 2)
  stock Int     @default(0)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  saleItems SaleItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, sku])
  @@map("products")
}

// ─────────────────────────────────────────────
// Sales
// ─────────────────────────────────────────────

model Sale {
  id    String     @id @default(uuid())
  total Decimal    @db.Decimal(10, 2)
  items SaleItem[]

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@map("sales")
}

model SaleItem {
  id        String  @id @default(uuid())
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)

  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@map("sale_items")
}

// ─────────────────────────────────────────────
// Financial
// ─────────────────────────────────────────────

model FinancialEntry {
  id          String        @id @default(uuid())
  type        FinancialType
  amount      Decimal       @db.Decimal(10, 2)
  description String?
  date        DateTime      @default(now())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  createdAt DateTime @default(now())

  @@map("financial_entries")
}

enum FinancialType {
  INCOME
  EXPENSE
}